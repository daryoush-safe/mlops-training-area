# Copy to .env (compose reads it automatically from infra/ via --env-file or cwd).
# MinIO root credentials — also used by DVC as S3 credentials.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# For running DVC on the host (outside docker):
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# MLFlow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

# Base-model mirror (sqlgen.storage). The MinIO endpoint is auto-resolved from
# the vars above; set AWS_S3_ENDPOINT_URL to override. SQLGEN_MODEL_CACHE
# overrides where the mirrored model is materialised (defaults under HF_HOME).
# AWS_S3_ENDPOINT_URL=http://localhost:9000
# SQLGEN_MODEL_CACHE= 