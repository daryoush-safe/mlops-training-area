# MinIO root credentials
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# For running DVC on the host (outside docker):
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# MLFlow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

# Base-model mirror (sqlgen.storage). The MinIO endpoint is auto-resolved from
# the vars above; set AWS_S3_ENDPOINT_URL to override. SQLGEN_MODEL_CACHE
# overrides where the mirrored model is materialised (defaults under HF_HOME).
# AWS_S3_ENDPOINT_URL=http://localhost:9000
# SQLGEN_MODEL_CACHE=

# inference-api upstream addresses
PRUNER_BASE_URL=http://vllm-pruner:8001/v1
SQLGEN_BASE_URL=http://vllm-sqlgen:8000/v1
DB_SERVICE_URL=http://host.docker.internal:8003